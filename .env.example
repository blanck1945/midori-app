# Servidor
PORT=3333
APP_ENV=development
# JWT: en producción (Railway, etc.) usá siempre el mismo valor entre deploys; si cambia JWT_SECRET, los tokens ya emitidos dejan de ser válidos y hay que volver a iniciar sesión.
JWT_SECRET=cambia-esto-en-produccion

# Base de datos (libSQL): Turso remoto O archivo local
# Turso — URL del dashboard (`libsql://...`) y token (solo remoto):
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
# Sin TURSO_DATABASE_URL / DATABASE_URL se usa archivo local:
DATABASE_PATH=./data/midori.sqlite
# `true` por defecto: ejecuta lib/sql/schema.sql al arrancar. En prod Turso ya migrada: APPLY_SCHEMA_ON_STARTUP=false
# APPLY_SCHEMA_ON_STARTUP=true

# IA (Gemini) — opcional; sin clave se usa heurística
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Cloudflare R2 (fotos) — opcional en dev; en prod rellenar
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=plantcare-photos
# Base pública para URLs guardadas en BD (NO uses el endpoint S3:
#   https://<ACCOUNT_ID>.r2.cloudflarestorage.com/<bucket>
# Ese host es solo para la API firmada; el navegador obtiene 400 en GET público.
# Usá el dominio público del bucket: R2 → bucket → Settings → Public access (r2.dev o dominio propio).
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# URL pública del front (enlaces en emails de recuperación de contraseña; sin barra final)
FRONTEND_URL=http://localhost:3333

# Resend — envío de emails (recuperar contraseña). Sin RESEND_API_KEY en dev se loguea el enlace en consola.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Cliente — base URL del API si el front no es mismo origen (sin barra final)
# Vite expone VITE_* y NEXT_PUBLIC_* al bundle (ver vite.config envPrefix).
# VITE_PUBLIC_API_URL=http://localhost:3333
# NEXT_PUBLIC_API_URL=http://localhost:3333
